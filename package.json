  "scripts": {
    "dev": "concurrently  -n WEB,API -c magenta,cyan \"yarn web:dev\" \"yarn api:dev\"",
    "web:dev": "cd web && yarn dev",
    "api:dev": "cd api && yarn start:dev",
    "start": " concurrently -n WEB,API  -c magenta,cyan  \"yarn web:start\" \"yarn api:start\"",
    "web:start": "cd web && yarn build",
    "api:start": "cd backend && yarn start",
    "install": " concurrently -n WEB,API  -c magenta,cyan  \"yarn web:install\" \"yarn api:install\"",
    "web:install": "cd web && yarn install",
    "api:install": "cd api && yarn install"
  },
